# Symfony parameters
TZ=America/New_York
APP_ENV=prod
APP_SECRET=secret
APP_TIMEZONE=$TZ

# Google reCAPTCHA keys
RECAPTCHA_ENABLED=false
RECAPTCHA_PUBLIC_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECAPTCHA_PRIVATE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database and Redis credentials
DATABASE_TYPE=mysql
DATABASE_HOST=database
DATABASE_NAME=source_web_console
DATABASE_USERNAME=username
DATABASE_PASSWORD=password

CACHE_HOST=redis
CACHE_USERNAME=default
CACHE_PASSWORD=password

# SMTP credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=username
SMTP_PASSWORD=password

# SSL encryption passphrase
SSL_PHRASE=passphrase

# Google OAuth credentials
GOOGLE_CLIENT_ENABLED=false
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub OAuth credentials
GITHUB_CLIENT_ENABLED=false
GITHUB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
